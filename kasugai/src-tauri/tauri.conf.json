{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kasugai",
  "version": "1.2.0",
  "identifier": "com.kasugai.app",
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "plugins": {
    "updater": {
      "pubkey": "YOUR_PUBLIC_KEY_HERE",
      "endpoints": [
        "https://yamamoto-ryuzo.github.io/kasugai/download/latest.json"
      ]
    }
  }
}
